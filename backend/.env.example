# ── GitHub App credentials ──────────────────────────────────────
# From your GitHub App settings page
GITHUB_APP_ID=your_app_id_here
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem

# Personal Access Token (easier for Week 1 — swap to App auth in Week 3)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, pull_requests
GITHUB_TOKEN=ghp_your_token_here

# The secret you typed when creating the webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/codereviewai

# ── AI (added in Week 3) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
